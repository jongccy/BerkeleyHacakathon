# Required — Claude reconcile + personalization
ANTHROPIC_API_KEY=

# Optional — live alert scraping (npx tsx src/pipeline.ts --live)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Optional — SMS-style delivery (npx tsx src/pipeline.ts --send)
POKE_API_KEY=
TEST_TO_NUMBER=

# Optional — Twilio delivery (set DELIVERY=twilio)
DELIVERY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional — Fetch ASI:One instead of Anthropic (LLM_PROVIDER=asi1)
LLM_PROVIDER=
ASI1_API_KEY=
ASI1_MODEL=asi1-mini

# Optional — Google Places autocomplete on web form
GOOGLE_MAPS_API_KEY=

# Optional — server port (default 3000)
PORT=3000
